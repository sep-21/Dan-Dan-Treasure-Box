{
  "name": "frameforge",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop tool for animated WebP, GIF, MP4 crop, and video-to-GIF workflows.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc && vite build",
    "start": "electron .",
    "dist:win": "npm run build && npx electron-builder@26.0.12 --win nsis portable",
    "dist:mac": "npm run build && npx electron-builder@26.0.12 --mac dmg"
  },
  "build": {
    "appId": "com.frameforge.desktop",
    "productName": "FrameForge",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "FrameForge-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "cwebp-bin": "^8.0.0",
    "electron": "^35.0.0",
    "gif2webp-bin": "^5.0.0",
    "gifski": "^1.7.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3"
  }
}
